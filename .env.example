# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_URL=https://referkaro.app

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Gemini AI
GOOGLE_GEMINI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
# Production sender address (e.g. notifications@referkaro.app)
EMAIL_FROM=
# Set this in dev to redirect all emails to one address (leave empty in prod)
FORCE_EMAIL_TO=

# Admin
ADMIN_EMAIL=

# Proxy Email (for pooling referrals)
PROXY_EMAIL=
PROXY_EMAIL_DOMAIN=referkaro.app

# Testmail proxy inbox
TESTMAIL_API_KEY=
TESTMAIL_NAMESPACE=
TESTMAIL_TAG_PREFIX=referkaro
TESTMAIL_POLL_LIMIT=25
TESTMAIL_TIMESTAMP_FROM=

# Cron Secret (Vercel)
CRON_SECRET=

# Webhook Security
WEBHOOK_INBOUND_SECRET=
